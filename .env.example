# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── SSO Bridge ────────────────────────────────────────────────
# Shared secret between this app and your existing product.
# Must be at least 32 random characters.
# Your product signs JWTs with this secret; this app verifies them.
SSO_JWT_SECRET=replace-with-a-long-random-secret

# ── Intercom ──────────────────────────────────────────────────
# Found in: Intercom → Settings → Installation
NEXT_PUBLIC_INTERCOM_APP_ID=your-app-id

# Found in: Intercom → Settings → Developers → Access Tokens
INTERCOM_ACCESS_TOKEN=your-access-token

# Found in: Intercom → Settings → Installation → Identity Verification → Secret key
INTERCOM_IDENTITY_SECRET=your-identity-secret

# ── Supabase Webhook ──────────────────────────────────────────
# Any random string — set as the x-webhook-secret header in
# the Supabase webhook that calls /api/intercom/sync
SUPABASE_WEBHOOK_SECRET=replace-with-another-random-secret

# ── MultiTracks Playback API (setlist sync) ───────────────────
# Service account whose upcoming setlists auto-generate setlist chats.
MT_USERNAME=your-multitracks-email
MT_PASSWORD=your-multitracks-password

# Secret that authorizes the daily Vercel Cron call to /api/setlists/sync.
# Generate a long random string; set the SAME value in Vercel env vars.
CRON_SECRET=replace-with-a-long-random-secret
